        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/api/v1/donut/parse-json?raw_output={\"invoice_number\":\"INV001\",\"date\":\"2024-05-14\"}&document_type=invoice",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "v1", "donut", "parse-json"],
          "query": [
            {
              "key": "raw_output",
              "value": "{\"invoice_number\":\"INV001\",\"date\":\"2024-05-14\"}"
