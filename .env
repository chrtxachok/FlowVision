# ===========================================
# FLOWVISION OCR - Переменные окружения
# ===========================================

# -------------------------------------------
# Пути к данным и моделям
# -------------------------------------------
# Путь к обученной модели Donut
#LOCAL_MODEL_PATH=./models/donut-trained-final
#DONUT_MODEL_PATH=./models/donut-trained-final
#OCR_BACKEND=donut
#DONUT_DEVICE=cpu
#DONUT_MAX_LENGTH=512
#DONUT_IMAGE_WIDTH=1280
#DONUT_IMAGE_HEIGHT=960

# -------------------------------------------
# Пути
# -------------------------------------------
DATA_DIR=./data
LOGS_DIR=./logs
CACHE_DIR=./cache

# -------------------------------------------
# Настройки модели
# -------------------------------------------
INFERENCE_DEVICE=cpu
CONFIDENCE_THRESHOLD=0.7

# -------------------------------------------
# API
# -------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# -------------------------------------------
# Логирование
# -------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# -------------------------------------------
# Ограничения
# -------------------------------------------
MAX_FILE_SIZE=10485760
MAX_BATCH_SIZE=10
REQUEST_TIMEOUT=300

# -------------------------------------------
# Безопасность
# -------------------------------------------
API_SECRET_KEY=your_production_secret_key_here
ALLOWED_ORIGINS=*