# ===========================================
# FLOWVISION OCR - Переменные окружения
# ===========================================

# -------------------------------------------
# Пути к данным и моделям
# -------------------------------------------
# Путь к обученной модели Donut
LOCAL_MODEL_PATH=./models/donut-based

# Базовая директория для данных
DATA_DIR=./dataset

# Директории для разных типов данных
DATA_RAW_DIR=./dataset/raw
DATA_DATASET_DIR=./dataset
DATA_ANNOTATED_DIR=./dataset/annotated
DATA_EXPORTS_DIR=./dataset/exports
DATA_MODELS_DIR=./models

# Директория для логов
LOGS_DIR=./logs

# Директория для кэша
CACHE_DIR=./cache

# -------------------------------------------
# Настройки модели
# -------------------------------------------
# Устройство для инференса: cpu или cuda
INFERENCE_DEVICE=cpu

# Максимальная длина последовательности для Donut
MODEL_MAX_LENGTH=1024

# Порог уверенности для извлечения полей
CONFIDENCE_THRESHOLD=0.7

# -------------------------------------------
# Настройки API
# -------------------------------------------
# Хост для прослушивания API
API_HOST=0.0.0.0

# Порт для API
API_PORT=8000

# Количество workers для uvicorn
API_WORKERS=2

# -------------------------------------------
# Логирование
# -------------------------------------------
# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Формат логирования
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Файл для логов (опционально)
LOG_FILE=./logs/app.log

# -------------------------------------------
# Ограничения
# -------------------------------------------
# Максимальный размер загружаемого файла (10 MB)
MAX_FILE_SIZE=10485760

# Максимальное количество файлов в батче
MAX_BATCH_SIZE=10

# Таймаут запроса в секундах
REQUEST_TIMEOUT=300

# -------------------------------------------
# HuggingFace Offline режим (для РФ)
# -------------------------------------------
HF_DATASETS_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_HUB_OFFLINE=1

# -------------------------------------------
# Docker настройки
# -------------------------------------------
# Имя Docker образа
DOCKER_IMAGE_NAME=flowvision-ocr

# Тег версии
DOCKER_IMAGE_TAG=latest

# -------------------------------------------
# Безопасность
# -------------------------------------------
# Секретный ключ для API (Семен, это для тебя)
API_SECRET_KEY=secret_key_for_api

# Разрешённые CORS origins (через запятую)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
# ALLOWED_ORIGINS=*


NO_PROXY=localhost,127.0.0.1,huggingface.co
HTTP_PROXY=
HTTPS_PROXY=